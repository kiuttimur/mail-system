DATABASE_URL=sqlite:///./mail_core.db

# URL второго микросервиса (в ЛР3)
COMMUNICATOR_URL=http://127.0.0.1:8002
COMMUNICATOR_TIMEOUT_SECONDS=2.0

# Cookie-based auth
AUTH_COOKIE_NAME=mail_core_session
AUTH_SESSION_TTL_MINUTES=10080
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# Username Telegram-бота без @, чтобы строить deep-link для привязки аккаунта
TELEGRAM_BOT_USERNAME=СommunicatorLR3bot
TELEGRAM_LINK_TOKEN_TTL_MINUTES=15
